NODE_ENV=production
TRUST_PROXY=1
CORS_ORIGINS=https://your-frontend-domain
SESSION_SECRET=replace-with-production-session-secret
SESSION_TTL_SECONDS=900
FINGERPRINT_SESSION_TTL_SECONDS=1800
STREAM_TTL_SECONDS=600
SIGNED_URL_EXPIRATION=60

